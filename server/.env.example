# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.xxxxxx.supabase.co:5432/postgres"

# JWT
JWT_SECRET="your-secret-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# AI Service (Google Gemini)
GEMINI_API_KEY="your-gemini-api-key-here"

# Server
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL="http://localhost:5173"

# Email Notifications (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"
# For testing use: onboarding@resend.dev
# For production: configure your verified domain email
RESEND_EMAIL_FROM="onboarding@resend.dev"

# Cron Job Schedule (cron format)
# Default: "0 9 * * *" = Every day at 9:00 AM
# For testing: "*/5 * * * *" = Every 5 minutes
NOTIFICATION_SCHEDULE="0 9 * * *"
